{
  "name": "pi-loom",
  "version": "0.1.0",
  "description": "Unified Pi Loom extension package for durable constitutional, research, initiative, specification, planning, ticket, critique, Ralph orchestration, documentation, and storage workflows.",
  "type": "module",
  "files": [
    "constitution/",
    "research/",
    "initiatives/",
    "specs/",
    "plans/",
    "ticketing/",
    "critique/",
    "docs/",
    "ralph-wiggum/",
    "storage/",
    "README.md",
    "LICENSE"
  ],
  "imports": {
    "#*": "./*"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "loom",
    "constitutional-memory",
    "research",
    "initiatives",
    "specifications",
    "planning",
    "ticketing",
    "critique",
    "ralph",
    "documentation",
    "storage"
  ],
  "pi": {
    "extensions": [
      "./constitution/extensions/index.ts",
      "./research/extensions/index.ts",
      "./initiatives/extensions/index.ts",
      "./specs/extensions/index.ts",
      "./plans/extensions/index.ts",
      "./ticketing/extensions/index.ts",
      "./critique/extensions/index.ts",
      "./ralph-wiggum/extensions/index.ts",
      "./docs/extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.57.0",
    "@mariozechner/pi-coding-agent": ">=0.57.0",
    "@sinclair/typebox": "^0.34.41"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "license": "MIT"
}
