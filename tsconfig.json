{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "constitution/**/*.ts",
    "research/**/*.ts",
    "initiatives/**/*.ts",
    "specs/**/*.ts",
    "plans/**/*.ts",
    "ticketing/**/*.ts",
    "critique/**/*.ts",
    "ralph/**/*.ts",
    "docs/**/*.ts",
    "storage/**/*.ts"
  ]
}
